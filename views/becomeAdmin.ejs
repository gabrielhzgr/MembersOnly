<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body>
    <%- include('partials/flash',{flash: locals.flashError}) %>
    <%- include('partials/nav') %>
    <main>
        <% if(!locals.user){ %>
            <p>You must first <a href="/login">Login</a> to become an admin</p>
        <% }else if(!user.membership_status){ %>
            <p>You must first <a href="/become-member">become a member</a> to be an admin</p>
        <% }else if(user.is_admin){ %>
            <p>You are already an admin</p>
        <% }else{  %>
            <form action="/update-admin-status" method="POST">
                <h1><%= title %></h1>
                <input type="text" name="userId" value="<%= user.id %>" hidden>
                <h2>Answer the riddle to become an admin:</h2>
                <p style="color: white; text-shadow: -1px 1px 0px black;">What gets wet while drying?</p>
                <textarea name="answer" id="answer" placeholder="Answer"></textarea>
                <button class="create btn">Submit</button>
            </form>
        <% } %>
    </main>
    <%- include('partials/btnAnimation') %>
</body>
</html>