<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body>
    <%- include('partials/flash') %>
   <main>
        <% if(!locals.user){ %>
            <p>You must first <a href="/login">Login</a> to become a member</p>
        <% }else if(user.membership_status){ %>
            <p>You are already a member</p>
        <% }else{  %>
            <form action="/update-member-status" method="POST">
                <h1><%= title %></h1>
                <input type="text" name="userId" value="<%= user.id %>" hidden>
                <h2>Answer the riddle to become a member</h2>
                <p style="color: white; text-shadow: -1px 1px 0px black;"><b>What word is always spelled wrong?</b></p>
                <textarea name="answer" id="answer" placeholder="Answer"></textarea>
                <button class="create btn">Submit</button>
            </form>
        <% } %>
    </main>
    <%- include('partials/btnAnimation') %>
</body>
</html>