<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body>
    <!-- No flashSuccess because that case redirects to / page-->
    <!-- This page is /login-->
    <%- include('partials/flash',{flash: flashError}) %>
    <%- include('partials/nav') %>
    <main>
        <form action="/login" method="POST">
            <h1><%= title %></h1>
            <div class="field">
                <label for="email">Email</label>
                <input type="email" name="username" id="email" placeholder="user@domain.com" required>
            </div>
            <div class="field">
                <label for="password">Password</label>
                <input type="password" name="password" id="password" required>
            </div>   
            <button class="create btn">Login</button>
            <p>Don't have an account yet? <a href="/sign-up">Register here</a></p>
    </form>

    </main>
   
    
    
    

    <%- include('partials/btnAnimation') %>
</body>
</html>